  document.getElementById('r1a').textContent=Math.round(subs*0.30).toLocaleString()+'회';
  document.getElementById('r1b').textContent=Math.round(subs*0.22).toLocaleString()+'회';
  document.getElementById('r1c').textContent=Math.round(subs*0.11).toLocaleString()+'회';
  document.getElementById('r1d').textContent=Math.round(subs*0.05).toLocaleString()+'회 미만';
  r.classList.add('show');
}

/* 계산기 2: 조회수 → 기대 좋아요/댓글 */
function c2f(){
  var views=parseFloat(document.getElementById('i2').value)||0;
  var r=document.getElementById('r2');
  if(views<=0){r.classList.remove('show');return;}
  document.getElementById('r2a').textContent=Math.round(views*0.02*0.9).toLocaleString()+'개';
  document.getElementById('r2b').textContent=Math.round(views*0.02*0.1).toLocaleString()+'개';
  document.getElementById('r2c').textContent=Math.round(views*0.01*0.9).toLocaleString()+'개';
  document.getElementById('r2d').textContent=Math.round(views*0.01*0.1).toLocaleString()+'개';
  r.classList.add('show');
}

/* 계산기 3: 현재 참여율 진단 */
function c3f(){
  var views=parseFloat(document.getElementById('i3v').value)||0;
  var likes=parseFloat(document.getElementById('i3l').value)||0;
  var comments=parseFloat(document.getElementById('i3c').value)||0;
  var r=document.getElementById('r3');
  if(views<=0){r.classList.remove('show');return;}
  var eng=((likes+comments)/views*100);
  var grade=eng>=2.0?'✅ 우수 (A그룹 수준)':eng>=1.0?'⚠️ 보통 (C그룹 수준)':eng>=0.5?'🔶 주의 (D/E그룹 수준)':'❌ 위험 — 즉각 개선 필요';
  var gc=eng>=2.0?'var(--green)':eng>=1.0?'var(--yellow)':eng>=0.5?'var(--orange)':'var(--red)';
  var needed=Math.max(0,Math.round(views*0.02-(likes+comments)));
  document.getElementById('r3a').textContent=eng.toFixed(2)+'%';
  document.getElementById('r3a').style.color=gc;
  document.getElementById('r3b').textContent=grade;
  document.getElementById('r3b').style.color=gc;
  document.getElementById('r3c').textContent=needed>0?needed.toLocaleString()+'개 추가 필요':'이미 충족 ✅';
  r.classList.add('show');
}

/* 차트 초기화 */
function initCharts(){
  if(typeof Chart==='undefined')return;
  Chart.defaults.color='#8892b0';
  Chart.defaults.font.family="'Segoe UI','Apple SD Gothic Neo',sans-serif";

  var grps=['A','B','C','D','E'];

  /* c1: 업로드 빈도 vs 채널점수 */
  new Chart(document.getElementById('c1'),{
    type:'scatter',
    data:{datasets:grps.map(g=>({
      label:SL[g],
      data:CH.filter(d=>d.s===g).map(d=>({x:d.f,y:d.h,label:d.n})),
      backgroundColor:SC[g]+'99',borderColor:SC[g],pointRadius:7,pointHoverRadius:10
    }))},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top',labels:{boxWidth:12,font:{size:12},color:'#8892b0'}},
        tooltip:{callbacks:{label:ctx=>`${ctx.raw.label}: 빈도 ${ctx.raw.x}회/주, 점수 ${ctx.raw.y}`}}
      },
      scales:{
        x:{title:{display:true,text:'업로드 빈도 (회/주)',color:'#8892b0'},grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}},
        y:{title:{display:true,text:'채널점수',color:'#8892b0'},min:0,max:60,grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}}
      }
    }
  });

  /* c2: 최대 공백 vs 채널점수 */
  new Chart(document.getElementById('c2'),{
    type:'scatter',
    data:{datasets:grps.map(g=>({
      label:SL[g],
      data:CH.filter(d=>d.s===g).map(d=>({x:d.g,y:d.h,label:d.n})),
      backgroundColor:SC[g]+'99',borderColor:SC[g],pointRadius:7,pointHoverRadius:10
    }))},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top',labels:{boxWidth:12,font:{size:12},color:'#8892b0'}},
        tooltip:{callbacks:{label:ctx=>`${ctx.raw.label}: 공백 ${ctx.raw.x}일, 점수 ${ctx.raw.y}`}}
      },
      scales:{
        x:{title:{display:true,text:'최대 업로드 공백 (일)',color:'#8892b0'},grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}},
        y:{title:{display:true,text:'채널점수',color:'#8892b0'},min:0,max:60,grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}}
      }
    }
  });

  /* c3: CV vs 참여도 */
  new Chart(document.getElementById('c3'),{
    type:'scatter',
    data:{datasets:grps.map(g=>({
      label:SL[g],
      data:CH.filter(d=>d.s===g).map(d=>({x:d.cv,y:d.e,label:d.n})),
      backgroundColor:SC[g]+'99',borderColor:SC[g],pointRadius:7,pointHoverRadius:10
    }))},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top',labels:{boxWidth:12,font:{size:12},color:'#8892b0'}},
        tooltip:{callbacks:{label:ctx=>`${ctx.raw.label}: CV ${ctx.raw.x}, 참여도 ${ctx.raw.y}%`}}
      },
      scales:{
        x:{title:{display:true,text:'CV (업로드 불규칙성)',color:'#8892b0'},grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}},
        y:{title:{display:true,text:'참여도 (%)',color:'#8892b0'},min:0,max:4,grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}}
      }
    }
  });

  /* c4: 구독자 대비 조회율 vs 채널점수 */
  new Chart(document.getElementById('c4'),{
    type:'scatter',
    data:{datasets:grps.map(g=>({
      label:SL[g],
      data:CH.filter(d=>d.s===g).map(d=>({x:d.v,y:d.h,label:d.n})),
      backgroundColor:SC[g]+'99',borderColor:SC[g],pointRadius:7,pointHoverRadius:10
    }))},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top',labels:{boxWidth:12,font:{size:12},color:'#8892b0'}},
        tooltip:{callbacks:{label:ctx=>`${ctx.raw.label}: 조회율 ${ctx.raw.x}, 점수 ${ctx.raw.y}`}}
      },
      scales:{
        x:{title:{display:true,text:'구독자 대비 조회율',color:'#8892b0'},grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}},
        y:{title:{display:true,text:'채널점수',color:'#8892b0'},min:0,max:60,grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#8892b0'}}
      }
    }
  });

  /* c5: 레이더 — 그룹별 5개 지표 */
  var maxF=9,maxG=90,maxCV=9,maxT=130,maxH=55;
  function grpAvg(g,fn){var arr=CH.filter(d=>d.s===g);return arr.reduce((s,d)=>s+fn(d),0)/arr.length;}
  function norm(v,max){return Math.min(100,Math.max(0,v/max*100));}

  var radarDatasets=grps.map(g=>({
    label:SL[g],
    data:[
      norm(grpAvg(g,d=>d.f),maxF),
      norm(maxG-grpAvg(g,d=>d.g),maxG),
      norm(maxCV-grpAvg(g,d=>d.cv),maxCV),
      norm(grpAvg(g,d=>d.v*100),75),
      norm(grpAvg(g,d=>d.e),3.5)
    ],
    borderColor:SC[g],backgroundColor:SC[g]+'28',
    pointBackgroundColor:SC[g],borderWidth:2.5,pointRadius:5
  }));

  new Chart(document.getElementById('c5'),{
    type:'radar',
    data:{
      labels:['업로드 빈도','공백 안정성','리듬 규칙성(CV역)','구독자대비조회율','참여도'],
      datasets:radarDatasets
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{callbacks:{label:ctx=>`${ctx.dataset.label}: ${ctx.raw.toFixed(1)}점`}}
      },
      scales:{
        r:{
          min:0,max:100,
          ticks:{stepSize:25,color:'#555b7a',backdropColor:'transparent',font:{size:10}},
          pointLabels:{color:'#c0c8e8',font:{size:13,weight:'700'}},
          grid:{color:'rgba(255,255,255,0.08)'},
          angleLines:{color:'rgba(255,255,255,0.08)'}
        }
      }
    }
  });
}

/* DOMContentLoaded */
document.addEventListener('DOMContentLoaded',function(){
  applyTable();
  initCharts();
});
</script>
